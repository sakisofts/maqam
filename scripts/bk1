$this->params['breadcrumbs'][] = $this->title;
?>
<div class="reservation-index">

    <h1><?= Html::encode($this->title) ?></h1>

    <p>
        <?= Html::a('Create Reservation', ['create'], ['class' => 'btn btn-success']) ?>
    </p>

    <?= GridView::widget([
        'dataProvider' => $dataProvider,
        'filterModel' => $searchModel,
        'columns' => [
            'reservation_number',
            [
                'attribute' => 'package_id',
                'value' => 'package.name',
            ],
            'reservation_date:datetime',
            'number_of_pilgrims',
            [
                'attribute' => 'status',
                'filter' => [
                    Reservation::STATUS_PENDING => 'Pending',
                    Reservation::STATUS_CONFIRMED => 'Confirmed',
                    Reservation::STATUS_CANCELLED => 'Cancelled',
                    Reservation::STATUS_COMPLETED => 'Completed',
                ],
            ],
            'total_amount:currency',
            'amount_paid:currency',
            'balance_due:currency',
            [
                'class' => 'yii\grid\ActionColumn',
                'template' => '{view} {update} {delete} {payment}',
                'buttons' => [
                    'payment' => function ($url, $model, $key) {
                        if ($model->status === Reservation::STATUS_PENDING ||
                            $model->status === Reservation::STATUS_CONFIRMED) {
                            return Html::a(
                                '<span class="glyphicon glyphicon-credit-card"></span>',
                                ['/payment/create', 'reservationId' => $model->id],
                                ['title' => 'Make Payment']
                            );
                        }
                        return '';
                    },
                    'update' => function ($url, $model, $key) {
                        if ($model->status === Reservation::STATUS_PENDING) {
                            return Html::a(
                                '<span class="glyphicon glyphicon-pencil"></span>',
                                $url,
                                ['title' => 'Update']
                            );
                        }
                        return '';
                    },
                    'delete' => function ($url, $model, $key) {
                        if ($model->status === Reservation::STATUS_PENDING) {
                            return Html::a(
                                '<span class="glyphicon glyphicon-trash"></span>',
                                $url,
                                [
                                    'title' => 'Cancel',
                                    'data-confirm' => 'Are you sure you want to cancel this reservation?',
                                    'data-method' => 'post',
                                ]
                            );
                        }
                        return '';
                    },
                ],
            ],
        ],
    ]); ?>
</div>

