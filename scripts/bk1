        'model' => $model,
        'attributes' => [
            'payment_number',
            [
                'attribute' => 'reservation_id',
                'value' => $model->reservation->reservation_number,
            ],
            'amount:currency',
            'payment_date:datetime',
            'payment_method',
            'transaction_id',
            'payment_status',
            'payment_type',
            'notes:ntext',
            'receipt_number',
            'created_at:datetime',
            'updated_at:datetime',
        ],
    ]) ?>
</div>

