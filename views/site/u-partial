<div class="activity-log">
    <div class="box box-primary">
        <div class="box-header with-border">
            <h3 class="box-title">Account Activity</h3>
            <div class="box-tools">
                <div class="input-group input-group-sm" style="width: 150px;">
                    <input type="text" name="table_search" class="form-control pull-right" placeholder="Search activities">
                    <div class="input-group-btn">
                        <button type="submit" class="btn btn-default"><i class="fa fa-search"></i></button>
                    </div>
                </div>
            </div>
        </div>
        <div class="box-body">
            <div class="timeline">
                <?php
                $currentDate = null;
                foreach ($activities as $activity):
                    $activityDate = Yii::$app->formatter->asDate($activity['created_at']);
                    if ($currentDate !== $activityDate):
                        $currentDate = $activityDate;
                        ?>
                        <div class="time-label">
                            <span class="bg-blue"><?= $activityDate ?></span>
                        </div>
                    <?php endif; ?>

                    <div>
                        <i class="fa fa-<?= $activity['icon'] ?> bg-<?= $activity['type'] ?>"></i>
                        <div class="timeline-item">
                            <span class="time"><i class="fa fa-clock-o"></i> <?= Yii::$app->formatter->asTime($activity['created_at']) ?></span>
                            <h3 class="timeline-header"><?= Html::encode($activity['title']) ?></h3>
                            <?php if (!empty($activity['description'])): ?>
                                <div class="timeline-body">
                                    <?= Html::encode($activity['description']) ?>
                                </div>
                            <?php endif; ?>

                            <?php if (!empty($activity['location']) || !empty($activity['ip_address'])): ?>
                                <div class="timeline-footer">
                                    <?php if (!empty($activity['location'])): ?>
                                        <span class="text-muted"><i class="fa fa-map-marker"></i> <?= Html::encode($activity['location']) ?></span>
                                    <?php endif; ?>

                                    <?php if (!empty($activity['ip_address'])): ?>
                                        <span class="text-muted"><i class="fa fa-globe"></i> <?= Html::encode($activity['ip_address']) ?></span>
                                    <?php endif; ?>

                                    <?php if ($activity['type'] == 'danger'): ?>
                                        <?= Html::a('<i class="fa fa-ban"></i> Report Suspicious Activity', ['user/report-suspicious', 'id' => $activity['id']], [
                                            'class' => 'btn btn-danger btn-xs',
                                            'data' => [
                                                'confirm' => 'Are you sure you want to report this activity as suspicious?',
                                                'method' => 'post',
                                            ],
                                        ]) ?>
                                    <?php endif; ?>
                                </div>
                            <?php endif; ?>
                        </div>
                    </div>
                <?php endforeach; ?>

                <div>
                    <i class="fa fa-clock-o bg-gray"></i>
                </div>
            </div>

            <div class="text-center">
                <?= LinkPager::widget([
                    'pagination' => $pagination,
                ]); ?>
            </div>
        </div>
    </div>
</div>
